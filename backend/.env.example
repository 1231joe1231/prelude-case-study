# Required for LLM-backed rationales. When unset, ranking/rationale.py
# falls back to a deterministic synthesizer (still cites literal facts,
# just no natural-language polish). Demo runs without the key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by the rationale layer.
# Defaults to claude-haiku-4-5-20251001.
# RATIONALE_MODEL=claude-sonnet-4-6
